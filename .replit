modules = ["python-3.12", "web", "nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["pkg-config", "mariadb", "gcc"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python manage.py migrate --noinput && python manage.py collectstatic --noinput && gunicorn --bind=0.0.0.0:5000 --reuse-port movierecomend.wsgi:application"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "movierecomend.wsgi:application"]
build = ["bash", "-c", "pip install --only-binary=:all: -r requirements-run.txt || pip install --no-build-isolation -r requirements-run.txt && python manage.py migrate --noinput && python manage.py collectstatic --noinput"]
